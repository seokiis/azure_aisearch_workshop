# ===================================================================
# Azure AI Search 핸즈온 워크샵 환경설정 파일
# ===================================================================
# 이 파일을 복사하여 .env 파일을 만들고 실제 값을 입력하세요.
#
# Windows:   copy .env.sample .env
# macOS:     cp .env.sample .env
# Linux:     cp .env.sample .env
#
# ⚠️ 주의: .env 파일은 절대 Git에 커밋하지 마세요! (.gitignore에 포함됨)
# ===================================================================

# -------------------------------------------------------------------
# Azure AI Search 설정
# -------------------------------------------------------------------
# Azure Portal → Azure AI Search 리소스 → 개요 페이지에서 확인
SEARCH_ENDPOINT=https://your-search-service-name.search.windows.net

# Azure Portal → Azure AI Search 리소스 → 키 페이지에서 "기본 관리 키" 복사
SEARCH_ADMIN_KEY=your-admin-key-here

# 인덱스 이름 (변경하지 마세요)
SEARCH_INDEX_NAME=products-index

# -------------------------------------------------------------------
# Azure OpenAI 설정
# -------------------------------------------------------------------
# Azure Portal → Azure OpenAI 리소스 → 키 및 엔드포인트에서 확인
# 또는 Azure AI Studio (https://ai.azure.com)에서 확인
AZURE_OPEN_AI_ENDPOINT=https://your-openai-resource-name.openai.azure.com

# Azure Portal → Azure OpenAI 리소스 → 키 및 엔드포인트에서 "KEY 1" 복사
AZURE_OPEN_AI_KEY=your-openai-key-here

# -------------------------------------------------------------------
# 모델 배포 이름
# -------------------------------------------------------------------
# Azure AI Studio → 배포 탭에서 확인
# 아래 이름으로 배포했다면 변경하지 마세요.
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini

# API 버전 (변경하지 마세요)
AZURE_OPENAI_API_VERSION=2024-06-01

# ===================================================================
# 설정 완료 후:
# 1. VS Code에서 01-setup/test_connection.ipynb 실행
# 2. 모든 연결 테스트가 성공하는지 확인
# ===================================================================